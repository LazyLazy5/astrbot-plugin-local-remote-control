{
  "admin_uids": {
    "description": "允许使用终端模式的发送者 ID 列表；留空则使用 AstrBot 全局管理员",
    "type": "list",
    "default": []
  },
  "work_dir": {
    "description": "路径沙盒根目录；留空则使用插件目录下 workspace",
    "type": "string",
    "default": ""
  },
  "allow_git": {
    "description": "是否允许 /git status",
    "type": "bool",
    "default": true
  },
  "hapi_endpoint": {
    "description": "HAPI Hub 地址，例如 http://127.0.0.1:3000",
    "type": "string",
    "default": ""
  },
  "access_token": {
    "description": "HAPI access token；可按 HAPI 约定使用 token:namespace",
    "type": "string",
    "default": ""
  },
  "proxy_url": {
    "description": "HAPI HTTP 代理，可留空",
    "type": "string",
    "default": ""
  },
  "jwt_lifetime": {
    "description": "HAPI JWT 有效期秒数",
    "type": "int",
    "default": 900
  },
  "refresh_before_expiry": {
    "description": "JWT 过期前多少秒刷新",
    "type": "int",
    "default": 180
  },
  "enable_codex_app_bridge": {
    "description": "是否允许使用 /codexbridge on",
    "type": "bool",
    "default": true
  }
}
